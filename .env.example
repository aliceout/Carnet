# ─────────────────────────────────────────────────────────────────
# Variables d'environnement pour Carnet
#
# Ce fichier est un TEMPLATE versionné. Il liste les clés attendues
# par la stack (Astro + Payload + Postgres + Mail).
#
# En prod : généré automatiquement par scripts/deploy.sh via
#   `infisical export --env=prod --path=/<sub> --format=dotenv >> .env`
# En dev  : tu fetches l'env "dev" d'Infisical self-hosted (qui contient
#   les valeurs locales : Postgres docker, Mailpit, etc.) via DvSetup
#   (VS Code) ou en CLI :
#   `infisical export --domain=https://env.backlice.dev \
#      --projectId=<id> --env=dev --path=/ --format=dotenv > .env`
#
# Le `.env` réel est gitignored (cf .gitignore). Ne commit JAMAIS de
# valeurs en clair.
# ─────────────────────────────────────────────────────────────────


# ─── Postgres (interne docker, jamais exposé sur le host) ────────
# Path Infisical : prod/postgres
POSTGRES_USER=payload
POSTGRES_PASSWORD=
POSTGRES_DB=carnet


# ─── Payload CMS (admin + API sous /cms/*) ───────────────────────
# Path Infisical : prod/payload
# PAYLOAD_SECRET : random 64+ chars, généré une fois
#   (ex: openssl rand -hex 32)
# PAYLOAD_PUBLIC_SERVER_URL : domaine racine sans /cms (le routage
#   /cms/admin et /cms/api est config côté code Payload)
# PAYLOAD_INTERNAL_URL : URL interne docker, utilisée par Astro
#   server-side pour fetcher Payload sans passer par internet
PAYLOAD_SECRET=
PAYLOAD_PUBLIC_SERVER_URL=https://carnet.aliceosdel.org
PAYLOAD_INTERNAL_URL=http://payload:3001


# ─── Astro front (Node SSR) ──────────────────────────────────────
# Path Infisical : prod/web
# ASTRO_PUBLIC_PAYLOAD_URL : domaine public servant les médias (côté
#   navigateur) — habituellement = PAYLOAD_PUBLIC_SERVER_URL.
ASTRO_PUBLIC_PAYLOAD_URL=https://carnet.aliceosdel.org


# ─── Mail backend (auth Payload uniquement, pas de form contact) ─
# Path Infisical : prod/smtp
# Les vars SMTP_* sont consommées par Payload pour les mails
# d'invitation, OTP 2FA et notifications de sécurité. Le service
# `mail` du compose route via le même SMTP — utile si on ajoute
# plus tard un formulaire ou des notifications éditoriales.
#
# Ces valeurs ne servent qu'en prod. En dev local, `pnpm dev:api`
# overrident automatiquement ces vars pour pointer sur Mailpit
# (UI http://localhost:8025) — tu n'as rien à toucher ici.
SMTP_HOST=mail.infomaniak.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM=carnet@aliceosdel.org
SMTP_FROM_NAME=Carnet
MAIL_TO=carnet@aliceosdel.org
# Path Infisical : prod/web
RATE_LIMIT_PER_HOUR=10
ALLOWED_ORIGIN=https://carnet.aliceosdel.org


# ─── Auth (invitations + 2FA + sessions) ─────────────────────────
# Toutes optionnelles, valeurs par défaut entre parenthèses.
# INVITATION_TTL_DAYS       — durée de validité du lien d'invitation (7)
# OTP_TTL_MINUTES           — durée de validité d'un code OTP email (10)
# TRUSTED_DEVICE_TTL_DAYS   — durée d'un appareil de confiance après 2FA (7)
# SESSION_INACTIVE_HOURS    — logout auto après cette durée d'inactivité (48)
# STEP_UP_TTL_MINUTES       — fenêtre où un mdp re-saisi reste valide
#                             pour les actions sensibles (10)
# PAYLOAD_INSECURE_COOKIES  — mettre "true" UNIQUEMENT pour debug HTTP en dev
INVITATION_TTL_DAYS=7
OTP_TTL_MINUTES=10
TRUSTED_DEVICE_TTL_DAYS=7
SESSION_INACTIVE_HOURS=48
STEP_UP_TTL_MINUTES=10
