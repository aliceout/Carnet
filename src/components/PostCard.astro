---
/**
 * Item de flux d'accueil — grille `120px 1fr 200px`, gap 48 px.
 * Réutilisé sur la home, la page d'un thème individuel et la
 * future page archives par série.
 *
 * Colonne gauche : numéro + date sur deux lignes + temps de lecture
 * Colonne centre : kicker + titre + chapô (max 580 px)
 * Colonne droite : « Lire → » en accent + tags inline
 *
 * Hover : titre passe en accent.
 *
 * Réf : design_handoff_carnet/Carnet B.html → .item.
 */
import { formatDateFr, formatNumero } from '../lib/site';

type Theme = { id: number | string; slug: string; name: string };

export interface Props {
  numero: number;
  slug: string;
  title: string;
  type: 'analyse' | 'note' | 'fiche';
  themes?: Array<Theme | number | string> | null;
  publishedAt: string | Date;
  lede: string;
  readingTime?: number | null;
  /** Affiche/masque les chips thèmes côté droit (utile sur la page d'un thème). */
  showThemes?: boolean;
}

const {
  numero,
  slug,
  title,
  type,
  themes,
  publishedAt,
  lede,
  readingTime,
  showThemes = true,
} = Astro.props;

const TYPE_LABEL: Record<Props['type'], string> = {
  analyse: 'Analyse',
  note: 'Note de lecture',
  fiche: 'Fiche',
};

// Sépare la date "14 avril 2026" en "14 avril" + "2026" sur deux lignes
const dateFr = formatDateFr(publishedAt);
const dateParts = dateFr.split(' ');
const dateDay = dateParts.slice(0, 2).join(' ');
const dateYear = dateParts.slice(2).join(' ');

const populatedThemes = (themes ?? []).filter(
  (t): t is Theme => typeof t === 'object' && t !== null && 'slug' in t,
);
const themeSlugs = populatedThemes.map((t) => t.slug).join(' ');

const readingLabel = readingTime
  ? type === 'fiche'
    ? 'fiche'
    : `${readingTime} min`
  : type === 'fiche'
  ? 'fiche'
  : null;
---

<article
  class="item"
  data-type={type}
  data-themes={themeSlugs}
>
  <a class="lcol" href={`/billets/${slug}/`} aria-hidden="true" tabindex="-1">
    <div class="num">{formatNumero(numero)}</div>
    <div class="date">{dateDay}</div>
    <div>{dateYear}</div>
    {readingLabel && <div class="read">{readingLabel}</div>}
  </a>
  <a class="ccol" href={`/billets/${slug}/`}>
    <div class="kicker">
      {TYPE_LABEL[type]}
      {showThemes && populatedThemes.length > 0 && (
        <span class="theme">
          {' · '}
          {populatedThemes.map((t, i) => (
            <>
              {i > 0 && ', '}
              <span>{t.name}</span>
            </>
          ))}
        </span>
      )}
    </div>
    <h2>{title}</h2>
    <p>{lede}</p>
  </a>
  <a class="rcol" href={`/billets/${slug}/`}>
    <div class="lk">Lire →</div>
    {showThemes && populatedThemes.length > 0 && (
      <div class="tags">
        {populatedThemes.slice(0, 3).map((t) => (
          <span class="tag">#{t.slug}</span>
        ))}
      </div>
    )}
  </a>
</article>

<style>
  .item {
    display: grid;
    grid-template-columns: 120px 1fr 200px;
    gap: 48px;
    padding: calc(40px * var(--density-feed)) 0;
    border-bottom: 1px solid var(--color-rule);
    align-items: baseline;
  }
  .item a {
    color: inherit;
    text-decoration: none;
  }
  .item:hover h2 {
    color: var(--color-accent);
  }
  .item .lcol {
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--color-muted);
  }
  .item .num {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-ink);
  }
  .item .date {
    margin-top: 8px;
    font-size: 13px;
    color: var(--color-ink);
    font-weight: 500;
  }
  .item .read {
    margin-top: 12px;
    font-size: 11px;
  }
  .item .kicker {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 10px;
  }
  .item .kicker .theme {
    color: var(--color-muted);
  }
  .item h2 {
    font-size: 26px;
    line-height: 1.2;
    font-weight: 600;
    margin: 0 0 12px;
    letter-spacing: -0.3px;
    transition: color 0.12s;
  }
  .item p {
    font-size: 16px;
    line-height: 1.55;
    color: var(--color-body-soft);
    margin: 0;
    max-width: 580px;
  }
  .item .rcol {
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--color-muted);
    text-align: right;
  }
  .item .rcol .lk {
    color: var(--color-accent);
    font-weight: 500;
  }
  .item .rcol .tags {
    margin-top: 8px;
    display: flex;
    gap: 6px;
    justify-content: flex-end;
    flex-wrap: wrap;
  }
  .item .rcol .tag {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--color-muted);
  }

  @media (max-width: 900px) {
    .item {
      grid-template-columns: 90px 1fr;
      gap: 24px;
    }
    .item .rcol {
      grid-column: 1 / -1;
      text-align: left;
      padding-top: 8px;
    }
    .item .rcol .tags {
      justify-content: flex-start;
    }
  }
</style>
