---
/**
 * Vue d'ensemble des thèmes — /themes/
 *
 * Hero + grille 2 colonnes des thèmes avec compteur d'usages.
 * Chaque carte = `#slug` mono accent, nom du thème 24 px, compteur
 * à droite.
 *
 * Réf : design_handoff_carnet/Carnet B.html → PolePage (overview).
 */
import Layout from '../../layouts/Layout.astro';
import { fetchCollection, filterPublished } from '../../lib/payload';

type Theme = {
  id: number | string;
  slug: string;
  name: string;
  description?: string | null;
};

type PostLite = {
  id: number | string;
  draft?: boolean;
  themes?: Array<{ id: number | string; slug: string } | number | string> | null;
};

let themes: Theme[] = [];
let counts: Map<string, number> = new Map();
try {
  themes = await fetchCollection<Theme>('themes', {
    sort: 'name',
    limit: 100,
    depth: 0,
  });
  const posts = filterPublished(
    await fetchCollection<PostLite>('posts', { limit: 1000, depth: 0 }),
  );
  // post.themes en depth 0 est un array d'IDs ; on compte par theme.id
  const idToSlug = new Map<number | string, string>(themes.map((t) => [t.id, t.slug]));
  for (const post of posts) {
    for (const tref of post.themes ?? []) {
      const tid = typeof tref === 'object' && tref !== null ? tref.id : tref;
      const slug = idToSlug.get(tid as number | string);
      if (!slug) continue;
      counts.set(slug, (counts.get(slug) ?? 0) + 1);
    }
  }
} catch (err) {
  console.warn('[themes] fetch failed:', (err as Error).message);
}

// Tri : décroissant par usage, puis alpha
const sorted = themes.slice().sort((a, b) => {
  const ca = counts.get(a.slug) ?? 0;
  const cb = counts.get(b.slug) ?? 0;
  if (ca !== cb) return cb - ca;
  return a.name.localeCompare(b.name, 'fr');
});

const total = sorted.length;
---

<Layout
  title="Thèmes — Carnet"
  description="Les sujets de recherche du Carnet — taxonomie multivaluée et libre."
>
  <section class="hero">
    <div class="container">
      <div class="meta">Thèmes thématiques · {total} thème{total > 1 ? 's' : ''}</div>
      <h1>Les <em>thèmes</em> du carnet.</h1>
      <p class="lede">
        Chaque billet est rattaché à un ou plusieurs thèmes. La taxonomie
        est libre et évolue avec le carnet.
      </p>
    </div>
  </section>

  <section class="container themes-list">
    {sorted.length === 0 ? (
      <p class="empty">Aucun thème pour l'instant.</p>
    ) : (
      <div class="grid">
        {sorted.map((t) => {
          const count = counts.get(t.slug) ?? 0;
          return (
            <a class="theme-card" href={`/theme/${t.slug}/`}>
              <div class="left">
                <div class="ty mono">#{t.slug}</div>
                <div class="t">{t.name}</div>
                {t.description && <p class="desc">{t.description}</p>}
              </div>
              <div class="right">
                {count} billet{count > 1 ? 's' : ''}
              </div>
            </a>
          );
        })}
      </div>
    )}
  </section>
</Layout>

<style>
  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 80px;
  }

  .hero {
    padding: 72px 0 48px;
    border-bottom: 1px solid var(--color-rule);
  }
  .hero .meta {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 18px;
  }
  .hero h1 {
    font-size: 64px;
    line-height: 1.04;
    font-weight: 600;
    letter-spacing: -0.7px;
    margin: 0 0 20px;
  }
  .hero h1 em {
    font-weight: 500;
  }
  .hero p.lede {
    font-family: var(--font-serif);
    font-size: 20px;
    line-height: 1.55;
    color: var(--color-muted);
    max-width: 720px;
    margin: 0;
  }

  .themes-list {
    padding-top: 40px;
    padding-bottom: 40px;
  }
  .themes-list .empty {
    padding: 64px 0;
    color: var(--color-muted);
    text-align: center;
    font-family: var(--font-sans);
  }
  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }
  .theme-card {
    display: grid;
    grid-template-columns: 1fr 100px;
    gap: 24px;
    padding: 24px 0;
    border-top: 1px solid var(--color-rule);
    align-items: baseline;
    color: inherit;
    transition: color 0.12s;
  }
  .theme-card:nth-child(odd) {
    padding-right: 24px;
    border-right: 1px solid var(--color-rule);
  }
  .theme-card:nth-child(even) {
    padding-left: 24px;
  }
  .theme-card:hover .t {
    color: var(--color-accent);
  }
  .theme-card .ty {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-accent);
    margin-bottom: 8px;
    letter-spacing: 0.04em;
  }
  .theme-card .t {
    font-size: 24px;
    line-height: 1.2;
    font-weight: 600;
    margin: 0 0 8px;
    letter-spacing: -0.3px;
    transition: color 0.12s;
  }
  .theme-card .desc {
    font-family: var(--font-serif);
    font-size: 15px;
    line-height: 1.55;
    color: var(--color-muted);
    margin: 0;
  }
  .theme-card .right {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--color-muted);
    text-align: right;
  }

  @media (max-width: 900px) {
    .container {
      padding: 0 24px;
    }
    .hero h1 {
      font-size: 40px;
    }
    .grid {
      grid-template-columns: 1fr;
    }
    .theme-card:nth-child(odd) {
      padding-right: 0;
      border-right: 0;
    }
    .theme-card:nth-child(even) {
      padding-left: 0;
    }
  }
</style>
