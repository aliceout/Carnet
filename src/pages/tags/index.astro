---
/**
 * Vue d'ensemble des tags — /tags/
 *
 * Hero + liste alphabétique des tags avec leur compteur d'usages.
 * Couvre l'ex-issue #7 (index alphabétique des mots-clés).
 */
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import { fetchCollection, filterPublished } from '../../lib/payload';

type Tag = {
  id: number | string;
  slug: string;
  name: string;
};

type PostLite = {
  id: number | string;
  draft?: boolean;
  tags?: Array<{ id: number | string; slug: string } | number | string> | null;
};

let tags: Tag[] = [];
let counts = new Map<string, number>();
try {
  tags = await fetchCollection<Tag>('tags', {
    sort: 'name',
    limit: 1000,
    depth: 0,
  });
  const posts = filterPublished(
    await fetchCollection<PostLite>('posts', { limit: 1000, depth: 0 }),
  );
  // post.tags en depth 0 est un array d'IDs ; on compte par tag.id
  const idToSlug = new Map<number | string, string>(tags.map((t) => [t.id, t.slug]));
  for (const post of posts) {
    for (const tref of post.tags ?? []) {
      const tid = typeof tref === 'object' && tref !== null ? tref.id : tref;
      const slug = idToSlug.get(tid as number | string);
      if (!slug) continue;
      counts.set(slug, (counts.get(slug) ?? 0) + 1);
    }
  }
} catch (err) {
  console.warn('[tags] fetch failed:', (err as Error).message);
}

// Alphabétique strict (les tags sont non-éditoriaux : pas de tri par
// usage prioritaire comme pour les thèmes)
const sorted = tags.slice().sort((a, b) => a.name.localeCompare(b.name, 'fr'));
const total = sorted.length;
---

<Layout
  title="Tags — Carnet"
  description="Tous les mots-clés utilisés dans le Carnet — index alphabétique."
>
  <Hero
    kicker={`Index · ${total} tag${total > 1 ? 's' : ''}`}
    title="Les <em>tags</em> du carnet."
    lede="Mots-clés libres ajoutés au fil des billets. Cliquer sur un tag mène à la liste des billets qui l'utilisent."
  />

  <section class="container tags-list">
    {sorted.length === 0 ? (
      <p class="empty">Aucun tag pour l'instant.</p>
    ) : (
      <ul class="grid">
        {sorted.map((t) => {
          const count = counts.get(t.slug) ?? 0;
          return (
            <li>
              <a class="tag-card" href={`/tag/${t.slug}/`}>
                <span class="slug">#{t.slug}</span>
                <span class="name">{t.name}</span>
                <span class="count">
                  {count} billet{count > 1 ? 's' : ''}
                </span>
              </a>
            </li>
          );
        })}
      </ul>
    )}
  </section>
</Layout>

<style>
  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 80px;
  }

  .tags-list {
    padding-top: 40px;
    padding-bottom: 64px;
  }
  .tags-list .empty {
    padding: 64px 0;
    color: var(--color-muted);
    text-align: center;
    font-family: var(--font-sans);
  }

  .grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0;
    border-top: 1px solid var(--color-rule);
  }
  .grid li {
    border-bottom: 1px solid var(--color-rule);
  }

  .tag-card {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: baseline;
    gap: 16px;
    padding: 14px 12px;
    text-decoration: none;
    color: inherit;
    transition: background 0.12s;
  }
  .tag-card:hover {
    background: var(--color-citation-bg);
  }
  .tag-card:hover .name {
    color: var(--color-accent);
  }
  .tag-card .slug {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-muted);
  }
  .tag-card .name {
    font-family: var(--font-serif);
    font-size: 17px;
    color: var(--color-ink);
    transition: color 0.12s;
  }
  .tag-card .count {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-muted);
  }

  @media (max-width: 900px) {
    .container {
      padding: 0 24px;
    }
  }
</style>
