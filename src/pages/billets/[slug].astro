---
/**
 * Page article — /billets/<slug>/
 *
 * Structure (cf design_handoff_carnet/Carnet B.html → Article) :
 *  1. Barre de progression sticky 2 px (via Layout progressBar)
 *  2. Crumbs (Carnet / thème / n° XXX)
 *  3. Kicker (type · thèmes)
 *  4. h1 + deck (lede)
 *  5. Meta-strip (Publié | Lecture | Pôle | ID)
 *  6. Body Lexical avec lettrine (CSS first-letter), justify+hyphens
 *  7. Notes classiques en pied (vide tant que BlocksFeature pas câblée)
 *  8. Bibliographie (depuis post.bibliography, ancres #bib-<slug>)
 *  9. Bloc « Pour citer cet article » avec bouton Copier (JS clipboard)
 * 10. Bloc « Dans le même thème » (related posts)
 *
 * TOC flottant à gauche (position: fixed; left: 24px; top: 140px;
 * width: 200px), masqué <1300 px de viewport. Scroll spy via
 * IntersectionObserver pour highlight de l'item actif.
 */
import Layout from '../../layouts/Layout.astro';
import { fetchBySlug, fetchCollection, fetchSite } from '../../lib/payload';
import {
  extractToc,
  renderLexicalSidenotes,
  renderLexicalWithFootnotes,
} from '../../lib/lexical';
import {
  formatDateFr,
  formatNumero,
  formatPostByline,
  formatPostCitationChicago,
  type PostAuthorEntry,
} from '../../lib/site';
import { formatAuthorsChicago, formatTranslators } from '../../lib/format-authors';
import { highwireMeta } from '../../lib/citations';

type Theme = { id: number | string; slug: string; name: string };
type Tag = { id: number | string; slug: string; name: string };
type BibAuthor = {
  firstName?: string | null;
  lastName: string;
  role?: 'author' | 'editor' | 'translator';
};
type BiblioEntry = {
  id: number | string;
  slug: string;
  authors?: BibAuthor[] | null;
  authorLabel?: string | null;
  year: number;
  title: string;
  type?: string;
  publisher?: string;
  place?: string;
  pages?: string;
  journal?: string;
  volume?: string;
  url?: string;
  doi?: string;
};

type Post = {
  id: number | string;
  numero: number;
  slug: string;
  title: string;
  type: 'analyse' | 'note' | 'fiche';
  themes?: Theme[] | null;
  tags?: Tag[] | null;
  authors?: PostAuthorEntry[] | null;
  publishedAt: string;
  updatedAt?: string;
  lede: string;
  body?: unknown;
  bibliography?: BiblioEntry[] | null;
  readingTime?: number | null;
  draft?: boolean;
};

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/');

const post = await fetchBySlug<Post>('posts', slug);
if (!post || post.draft) {
  return Astro.rewrite('/404');
}

const TYPE_LABEL: Record<Post['type'], string> = {
  analyse: 'Analyse',
  note: 'Note de lecture',
  fiche: 'Fiche',
};

const themes = (post.themes ?? []).filter(
  (t): t is Theme => typeof t === 'object' && t !== null && 'slug' in t,
);
const primaryTheme = themes[0];

// Date FR + ISO
const publishedFr = formatDateFr(post.publishedAt);
const publishedIso = new Date(post.publishedAt).toISOString().slice(0, 10);
const readingLabel = post.readingTime
  ? post.type === 'fiche'
    ? 'fiche'
    : `≈ ${post.readingTime} min`
  : null;

// Site global — fournit l'identité (citation Chicago) et le mode
// d'affichage des notes (classique en pied / sidenotes en marge).
type SiteData = {
  reading?: { notesMode?: 'classic' | 'sidenotes' };
};
let site: SiteData = {};
try {
  site = await fetchSite<SiteData>();
} catch (err) {
  console.warn('[article] fetchSite failed:', (err as Error).message);
}
const notesMode: 'classic' | 'sidenotes' =
  site.reading?.notesMode === 'sidenotes' ? 'sidenotes' : 'classic';

// Body HTML rendu côté serveur depuis Lexical. En mode classique, on
// récupère bodyHtml + footnotesHtml (notes empilées en pied). En mode
// sidenotes, le rendu interleave les <aside class="marg"> juste après
// chaque bloc concerné — pas de footnotesHtml séparé.
const bodyHtml =
  notesMode === 'sidenotes'
    ? renderLexicalSidenotes(post.body)
    : renderLexicalWithFootnotes(post.body).bodyHtml;
const footnotesHtml =
  notesMode === 'classic' ? renderLexicalWithFootnotes(post.body).footnotesHtml : '';
const tocEntries = extractToc(post.body);

// Bibliographie
const biblio = (post.bibliography ?? []).filter(
  (b): b is BiblioEntry => typeof b === 'object' && b !== null && 'slug' in b,
);

// Posts liés (même thème principal, exclure le post courant)
let related: Array<{ slug: string; title: string; publishedAt: string }> = [];
if (primaryTheme) {
  try {
    const relatedRaw = await fetchCollection<Post>('posts', {
      where: [{ field: 'themes.slug', operator: 'equals', value: primaryTheme.slug }],
      limit: 10,
      sort: '-publishedAt',
      depth: 0,
    });
    related = relatedRaw
      .filter((p) => p.slug !== post.slug && !p.draft)
      .slice(0, 4)
      .map((p) => ({
        slug: p.slug,
        title: p.title,
        publishedAt: p.publishedAt,
      }));
  } catch (err) {
    console.warn('[article] related fetch failed:', (err as Error).message);
  }
}

const numLabel = formatNumero(post.numero);

// Auteur·ices du billet — byline lisible sous le titre et signature
// Chicago dans le bloc « Pour citer ». Cf issue #2.
const postAuthors = (post.authors ?? []) as PostAuthorEntry[];
const byline = formatPostByline(postAuthors);
const postCitation = formatPostCitationChicago(postAuthors);

// Si le billet n'a aucun·e auteur·ice renseigné·e (cas legacy ou
// ratage), on tombe sur un placeholder neutre. Chaque user a son
// propre `citationFormat` (cf Mon compte) qui surcharge l'heuristique
// dans formatPostCitationChicago.
const authorCitation = postCitation || 'Auteur·ice';

// Citation bibliographique du billet (Chicago author-date façon Carnet)
const articleUrl = new URL(Astro.url.pathname, Astro.site).toString();
const citationText = `${authorCitation}. « ${post.title} », Carnet, ${numLabel.replace('n° ', 'n° ')}, ${publishedFr}, ${articleUrl}.`;

// Métadonnées Highwire/Google Scholar pour que l'extension Zotero
// détecte automatiquement la citation à la visite de l'article (sans
// que l'utilisatrice ait besoin de cliquer un bouton). Cf
// src/lib/citations.ts.
const citationMeta = highwireMeta(
  {
    slug: post.slug,
    numero: post.numero,
    title: post.title,
    publishedAt: post.publishedAt,
    authors: postAuthors,
  },
  { articleUrl, accessedAt: new Date().toISOString().slice(0, 10) },
);
---

<Layout
  title={post.title + ' — Carnet'}
  description={post.lede}
  progressBar={true}
  bodyClass={`justify notes-${notesMode}`}
>
  {/* Métadonnées Highwire/Google Scholar — détection automatique de
      la citation par l'extension Zotero quand on visite la page. */}
  <Fragment slot="head">
    {citationMeta.map((m) => (
      <meta name={m.name} content={m.content} />
    ))}
  </Fragment>

  <!-- TOC flottant -->
  {tocEntries.length > 0 && (
    <aside class="toc" id="toc" aria-label="Sommaire">
      <div class="lbl">Sommaire</div>
      <a href="#intro" class="on" data-toc="intro">Introduction</a>
      {tocEntries.map((entry) => (
        <a
          href={`#${entry.id}`}
          data-toc={entry.id}
          class:list={[`level-${entry.level}`]}
        >
          {entry.text}
        </a>
      ))}
      {footnotesHtml && <a href="#notes" data-toc="notes">Notes</a>}
      {biblio.length > 0 && <a href="#biblio" data-toc="biblio">Bibliographie</a>}
      {post.type === 'analyse' && (
        <a href="#cite" data-toc="cite">Pour citer</a>
      )}
    </aside>
  )}

  <article class:list={['post', 'container', { 'no-toc': tocEntries.length === 0 }]}>
    <div class="crumbs">
      <a href="/">Carnet</a> &nbsp;/&nbsp;
      {TYPE_LABEL[post.type]}
      &nbsp;/&nbsp; {numLabel}
    </div>

    <h1>{post.title}</h1>
    {byline && <p class="byline">par {byline}</p>}
    <p class="deck">{post.lede}</p>

    <div class="meta-strip">
      <div>
        <div class="lbl">Publié</div>
        <time datetime={publishedIso}>{publishedFr}</time>
      </div>
      <div>
        <div class="lbl">Lecture</div>
        {readingLabel ?? '—'}
      </div>
      <div>
        <div class="lbl">Type</div>
        {TYPE_LABEL[post.type]}
      </div>
      <div>
        <div class="lbl">Thème</div>
        {primaryTheme ? primaryTheme.name : '—'}
      </div>
    </div>

    <div class="body-grid">
      <div class="col" id="intro">
        <Fragment set:html={bodyHtml} />
      </div>
    </div>

    {footnotesHtml && (
      <div class="footnotes-wrap" id="notes">
        <Fragment set:html={footnotesHtml} />
      </div>
    )}

    <div class="tail">
      {biblio.length > 0 && (
        <section id="biblio">
          <h3>Bibliographie</h3>
          <ul class="biblio">
            {biblio.map((b) => (
              <li id={`bib-${b.slug}`}>
                <span class="ba">{formatAuthorsChicago(b.authors)}</span>
                {`, ${b.year}, `}
                <em>{b.title}</em>
                {formatTranslators(b.authors) && `, ${formatTranslators(b.authors)}`}
                {b.publisher && `, ${b.place ? b.place + ', ' : ''}${b.publisher}`}
                {b.journal && `, ${b.journal}`}
                {b.volume && `, ${b.volume}`}
                {b.pages && `, p. ${b.pages}`}
                {b.url && (
                  <>
                    {' '}
                    <a href={b.url} class="ext" rel="noopener">{b.url}</a>
                  </>
                )}
                {!b.url && b.doi && (
                  <>
                    {' doi:'}
                    <a href={`https://doi.org/${b.doi}`} class="ext" rel="noopener">
                      {b.doi}
                    </a>
                  </>
                )}
                .
              </li>
            ))}
          </ul>
        </section>
      )}

      {post.tags && post.tags.length > 0 && (
        <section class="post-tags" aria-label="Tags">
          {post.tags
            .filter((t): t is Tag => typeof t === 'object' && t !== null)
            .map((t) => (
              <a class="post-tag" href={`/tag/${t.slug}/`}>
                #{t.slug}
              </a>
            ))}
        </section>
      )}

      {post.type === 'analyse' && (
        <section class="citation" id="cite">
          <div class="lbl">Pour citer cet article</div>
          <div class="body">
            {authorCitation}. « {post.title} », <em>Carnet</em>, {numLabel}, {publishedFr},
            <span class="url">{' '}{articleUrl}</span>.
          </div>
          <div class="acts">
            <button
              type="button"
              class="copy-btn"
              data-citation={citationText}
              aria-label="Copier la citation"
            >
              Copier
            </button>
            {/* Liens de téléchargement — formats académiques standards.
                Les routes correspondantes vivent dans src/pages/billets/
                [slug].bib.ts et [slug].ris.ts. Zotero importe RIS
                nativement, on pointe donc sur le même fichier ; et la
                détection auto via Highwire <meta> en <head> rend même
                ce bouton accessoire pour les utilisateurs avec
                l'extension installée. */}
            <a
              class="download-btn"
              href={`/billets/${post.slug}.bib`}
              download={`${post.slug}.bib`}
              aria-label="Télécharger la citation au format BibTeX"
            >
              BibTeX
            </a>
            <a
              class="download-btn"
              href={`/billets/${post.slug}.ris`}
              download={`${post.slug}.ris`}
              aria-label="Télécharger la citation au format RIS"
            >
              RIS
            </a>
            <a
              class="download-btn"
              href={`/billets/${post.slug}.ris`}
              download={`${post.slug}.ris`}
              aria-label="Importer la citation dans Zotero (format RIS)"
              title="Zotero importe RIS nativement"
            >
              Zotero
            </a>
          </div>
        </section>
      )}

      {related.length > 0 && primaryTheme && (
        <section class="related">
          <h3>Dans le même thème</h3>
          <div class="grid">
            {related.map((r) => (
              <a href={`/billets/${r.slug}/`}>
                <div class="d">{formatDateFr(r.publishedAt)}</div>
                <div class="t">{r.title}</div>
              </a>
            ))}
          </div>
        </section>
      )}
    </div>
  </article>
</Layout>

<style>
  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 80px;
  }

  /* Article */
  article.post {
    padding: 48px 80px 0;
  }
  /* Cibles d'ancres du Sommaire : on offre une marge de scroll pour
     que l'élément cliqué arrive ~1/3 du haut de la fenêtre, plutôt
     que collé sous la topbar sticky. */
  article.post :global(h2),
  article.post :global(h3),
  article.post #intro,
  article.post #notes,
  article.post #biblio,
  article.post #cite {
    scroll-margin-top: 33vh;
  }
  article.post .crumbs {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 18px;
  }
  article.post .crumbs a {
    color: var(--color-muted);
    transition: color 0.12s;
  }
  article.post .crumbs a:hover {
    color: var(--color-ink);
  }
  article.post h1 {
    font-size: 52px;
    line-height: 1.08;
    font-weight: 600;
    letter-spacing: -0.7px;
    margin: 0 0 12px;
  }
  article.post h1 em {
    font-weight: 500;
    color: var(--color-accent);
  }
  /* Byline « par X et Y » entre le titre et le chapô. Style sobre,
     italique muted. Cf issue #2. */
  article.post .byline {
    font-family: var(--font-serif);
    font-size: 16px;
    font-style: italic;
    color: var(--color-muted);
    margin: 0 0 20px;
  }
  article.post .deck {
    font-family: var(--font-serif);
    font-size: 22px;
    line-height: 1.5;
    color: var(--color-muted);
    margin: 0 0 32px;
  }
  article.post .meta-strip {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    padding: 20px 0;
    border-top: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--color-muted);
    margin-bottom: 48px;
  }
  article.post .meta-strip .lbl {
    color: var(--color-ink);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }

  /* Body grid + lettrine + justify */
  .body-grid {
    margin: 0;
  }
  .body-grid .col {
    font-family: var(--font-serif);
    font-size: 19px;
    line-height: 1.7;
    color: var(--color-body);
  }
  .body-grid .col :global(p) {
    margin: 0 0 1.2em;
  }
  /* Lettrine sur le tout premier paragraphe du corps */
  .body-grid .col :global(p:first-of-type::first-letter) {
    float: left;
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 90px;
    line-height: 0.82;
    margin: 8px 10px 0 0;
    color: var(--color-ink);
  }
  body.no-lettrine .body-grid .col :global(p:first-of-type::first-letter) {
    float: none;
    font-size: inherit;
    font-weight: inherit;
    margin: 0;
    line-height: inherit;
  }
  body.justify .body-grid .col :global(p),
  body.justify .body-grid .col :global(li),
  body.justify article.post .deck {
    text-align: justify;
    hyphens: auto;
    -webkit-hyphens: auto;
  }
  .body-grid .col :global(h2) {
    font-size: 30px;
    font-weight: 600;
    letter-spacing: -0.3px;
    margin: 48px 0 16px;
    font-family: var(--font-serif);
    text-align: left;
  }
  .body-grid .col :global(h3) {
    font-size: 22px;
    font-weight: 600;
    margin: 32px 0 12px;
  }
  .body-grid .col :global(blockquote) {
    font-size: 22px;
    line-height: 1.5;
    font-weight: 500;
    color: var(--color-ink);
    margin: 36px 0;
    padding: 0 0 0 22px;
    border-left: 2px solid var(--color-accent);
    text-align: left;
  }
  .body-grid .col :global(a.ext) {
    border-bottom: 1px solid var(--color-accent);
    color: inherit;
  }
  .body-grid .col :global(a.int) {
    border-bottom: 1px dotted var(--color-muted);
    color: inherit;
  }
  .body-grid .col :global(sup a) {
    color: var(--color-accent);
  }

  /* ── Blocks Lexical custom (rendus par renderLexicalWithFootnotes) ── */

  /* Footnote inline : <sup><a> qui pointe vers #fn-N */
  .body-grid .col :global(.fn-mark) {
    line-height: 0;
    font-size: 0.78em;
    margin-left: 1px;
  }
  .body-grid .col :global(.fn-mark a) {
    color: var(--color-accent);
    text-decoration: none;
    font-family: var(--font-sans);
    font-weight: 500;
  }
  .body-grid .col :global(.fn-mark a:hover) {
    text-decoration: underline;
  }

  /* BiblioInline : (Auteur, année) → #bib-<slug> */
  .body-grid .col :global(.biblio-inline) {
    color: var(--color-accent);
    border-bottom: 1px dotted var(--color-accent);
    text-decoration: none;
    transition: color 0.12s;
  }
  .body-grid .col :global(.biblio-inline:hover) {
    color: var(--color-ink);
    border-bottom-style: solid;
  }
  .body-grid .col :global(.biblio-inline-empty) {
    color: var(--color-muted);
    font-style: italic;
  }

  /* CitationBloc — citation longue avec source (ré-utilise le style
     blockquote existant + cite). */
  .body-grid .col :global(.block-citation) {
    /* hérite du style blockquote */
  }
  .body-grid .col :global(.citation-source) {
    display: block;
    margin-top: 12px;
    font-style: normal;
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--color-muted);
    text-align: left;
  }

  /* Figure (image + légende + crédit) */
  .body-grid .col :global(.block-figure) {
    margin: 32px 0;
  }
  .body-grid .col :global(.block-figure.align-center) {
    text-align: center;
  }
  .body-grid .col :global(.block-figure.align-wide) {
    /* Ne déborde pas du body-grid en mode classic, juste plus large */
    margin-left: -40px;
    margin-right: -40px;
  }
  .body-grid .col :global(.block-figure img) {
    max-width: 100%;
    height: auto;
    display: block;
  }
  .body-grid .col :global(.block-figure figcaption) {
    font-family: var(--font-sans);
    font-size: 12.5px;
    line-height: 1.55;
    color: var(--color-muted);
    margin-top: 8px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    text-align: left;
  }
  .body-grid .col :global(.block-figure .credit) {
    font-size: 11px;
  }

  /* Mode sidenotes — notes en marge à droite (cf issue #6).
     Activé par body.notes-sidenotes. La <aside class="marg"> est
     rendue inline juste après le bloc qui l'appelle, et flotte à
     droite via margin-right négatif pour sortir dans la gouttière. */
  body.notes-sidenotes .body-grid .col {
    padding-right: 240px;
    position: relative;
  }
  body.notes-sidenotes .body-grid .col :global(.marg) {
    float: right;
    clear: right;
    width: 200px;
    margin: 4px -240px 1.4em 16px;
    font-family: var(--font-sans);
    font-size: 13px;
    line-height: 1.55;
    color: var(--color-muted);
    text-align: left;
  }
  body.notes-sidenotes .body-grid .col :global(.marg-num) {
    display: inline-block;
    margin-right: 6px;
    color: var(--color-accent);
    font-weight: 600;
    font-size: 11px;
  }
  body.notes-sidenotes .body-grid .col :global(.marg .fn-back) {
    display: inline-block;
    margin-left: 6px;
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.9em;
    text-decoration: none;
  }
  body.notes-sidenotes .body-grid .col :global(.marg .fn-back:hover) {
    text-decoration: underline;
  }
  /* Sous 1100px, plus la place pour la gouttière — fallback en bloc
     intercalé, encadré accent à gauche pour distinguer le contenu. */
  @media (max-width: 1100px) {
    body.notes-sidenotes .body-grid .col {
      padding-right: 0;
    }
    body.notes-sidenotes .body-grid .col :global(.marg) {
      float: none;
      width: auto;
      margin: 16px 0;
      padding: 10px 14px;
      border-left: 2px solid var(--color-accent);
      background: var(--color-citation-bg);
    }
  }

  /* Notes en pied d'article (style classique) */
  .footnotes-wrap {
    margin: 48px 0 0;
  }
  .footnotes-wrap :global(.footnotes-classic) {
    border-top: 1px solid var(--color-rule);
    padding-top: 24px;
  }
  .footnotes-wrap :global(.footnotes-classic h3) {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink);
    margin: 0 0 14px;
  }
  .footnotes-wrap :global(.footnotes-classic ol) {
    font-family: var(--font-serif);
    font-size: 14px;
    line-height: 1.65;
    color: var(--color-body-soft);
    padding-left: 22px;
    margin: 0;
  }
  .footnotes-wrap :global(.footnotes-classic li) {
    margin-bottom: 8px;
  }
  .footnotes-wrap :global(.fn-back) {
    color: var(--color-accent);
    margin-left: 4px;
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 0.85em;
  }
  .footnotes-wrap :global(.fn-back:hover) {
    text-decoration: underline;
  }

  /* Tail (biblio, citation, related) */
  .tail {
    margin: 48px 0 0;
  }
  .tail h3 {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink);
    margin: 0 0 14px;
  }
  .tail ul.biblio {
    font-family: var(--font-serif);
    font-size: 14px;
    line-height: 1.65;
    color: var(--color-body-soft);
    padding-left: 22px;
    margin: 0;
  }
  .tail ul.biblio li {
    margin-bottom: 6px;
  }
  .tail ul.biblio .ba {
    font-weight: 500;
    color: var(--color-ink);
  }
  .tail ul.biblio a.ext {
    border-bottom: 1px solid var(--color-accent);
    color: inherit;
  }
  /* Tags discrets en pied de billet — mono muted, plus discrets que
     les chips de thèmes en couleur accent. Hover = accent. */
  .post-tags {
    margin-top: 32px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .post-tag {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-muted);
    text-decoration: none;
    padding: 2px 6px;
    border: 1px solid var(--color-rule);
    transition: color 0.12s, border-color 0.12s;
  }
  .post-tag:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .citation {
    background: var(--color-citation-bg);
    padding: 24px 28px;
    margin-top: 40px;
    border-radius: 4px;
  }
  .citation .lbl {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 10px;
  }
  .citation .body {
    font-family: var(--font-serif);
    font-size: 15px;
    line-height: 1.55;
    color: var(--color-ink);
  }
  .citation .body .url {
    font-family: var(--font-mono);
    font-size: 12px;
  }
  .citation .acts {
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--color-accent);
    margin-top: 12px;
    display: flex;
    gap: 16px;
    align-items: center;
  }
  .citation .acts .copy-btn {
    background: transparent;
    border: 0;
    padding: 0;
    color: var(--color-accent);
    cursor: pointer;
    font: inherit;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }
  .citation .acts .copy-btn:hover {
    color: var(--color-ink);
  }
  .citation .acts .copy-btn.copied {
    color: var(--color-ink);
    text-decoration: none;
  }
  .citation .acts .download-btn {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }
  .citation .acts .download-btn:hover {
    color: var(--color-ink);
  }

  .related {
    margin-top: 56px;
    padding-top: 32px;
    border-top: 1px solid var(--color-rule);
  }
  .related .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .related a {
    padding: 14px 0;
    border-top: 1px solid var(--color-rule);
    display: block;
    color: var(--color-ink);
    transition: color 0.12s;
  }
  .related a:hover .t {
    color: var(--color-accent);
  }
  .related .d {
    font-family: var(--font-sans);
    font-size: 11px;
    color: var(--color-muted);
    margin-bottom: 4px;
  }
  .related .t {
    font-size: 17px;
    font-weight: 600;
    line-height: 1.3;
  }

  /* TOC flottant — visible uniquement sur viewports larges. Ancré sur
     le bord gauche du .container (max-width 1280) plutôt que sur le
     viewport, pour garder un gap constant avec le contenu de l'article
     quelle que soit la largeur de la fenêtre. Le calc max() évite le
     dépassement quand le viewport est plus étroit que le container. */
  .toc {
    position: fixed;
    left: max(24px, calc((100vw - 1280px) / 2 + 24px));
    top: 140px;
    width: 220px;
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--color-muted);
    line-height: 1.5;
    z-index: 4;
  }
  .toc .lbl {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ink);
    margin-bottom: 10px;
  }
  .toc a {
    display: block;
    padding: 4px 0;
    color: var(--color-muted);
    border-left: 2px solid transparent;
    padding-left: 10px;
    margin-left: -10px;
    transition: color 0.12s, border-left-color 0.12s;
  }
  .toc a.level-3 {
    padding-left: 22px;
  }
  .toc a.on {
    color: var(--color-ink);
    border-left-color: var(--color-accent);
  }
  @media (max-width: 1299px) {
    .toc {
      display: none;
    }
  }
  /* À partir de 1300px le TOC est visible. Le TOC étant ancré sur le
     bord gauche du container (24 px d'inset), il occupe les 244 px
     suivants (24 + 220). On place le contenu de l'article à 280 px,
     soit un gap constant de 36 px avec la fin du TOC, indépendant
     de la largeur du viewport.
     Largeur utile du contenu = 1280 (container) - 280 (left) - 80
     (right) = 920 px.
     Si pas de TOC (article sans h2 → tocEntries vide), on garde la
     même largeur utile (920 px) mais on centre via padding symétrique :
     (1280 - 920) / 2 = 180 px de chaque côté. */
  @media (min-width: 1300px) {
    article.post {
      padding-left: 280px;
    }
    article.post.no-toc {
      padding-left: 180px;
      padding-right: 180px;
    }
  }

  @media (max-width: 900px) {
    article.post {
      padding: 32px 24px 0;
    }
    .container {
      padding: 0 24px;
    }
    article.post h1 {
      font-size: 36px;
    }
    article.post .meta-strip {
      grid-template-columns: 1fr 1fr;
    }
    .related .grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // TOC actif au scroll (IntersectionObserver) + bouton Copier citation.
  // Lecture sans JS = TOC visible mais pas de highlight, citation
  // affichée mais pas de copie clipboard (le placeholder reste).
  (function () {
    // ─── TOC scroll spy ────────────────────────────────────────
    const tocLinks = Array.from(
      document.querySelectorAll<HTMLAnchorElement>('.toc a[data-toc]'),
    );
    if (tocLinks.length) {
      const ids = tocLinks.map((a) => a.dataset.toc).filter((id): id is string => !!id);
      const sections = ids
        .map((id) => document.getElementById(id))
        .filter((el): el is HTMLElement => el !== null);

      function setActive(id: string) {
        for (const a of tocLinks) {
          a.classList.toggle('on', a.dataset.toc === id);
        }
      }

      // Scrollspy basé sur la position : on prend la dernière section
      // dont le haut a dépassé la ligne 1/3 du viewport (cohérent avec
      // `scroll-margin-top: 33vh`). Évite le bug où #intro (qui contient
      // tous les h2/h3) gagnait en permanence avec IntersectionObserver.
      if (sections.length > 0) {
        let raf = 0;
        const updateActive = () => {
          raf = 0;
          const line = window.innerHeight * 0.33;
          let activeId = sections[0].id;
          for (const sec of sections) {
            if (sec.getBoundingClientRect().top <= line) activeId = sec.id;
            else break;
          }
          setActive(activeId);
        };
        const onScroll = () => {
          if (raf) return;
          raf = requestAnimationFrame(updateActive);
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        window.addEventListener('resize', onScroll, { passive: true });
        updateActive();
      }

      // Smooth scroll au clic
      for (const a of tocLinks) {
        a.addEventListener('click', (e) => {
          const id = a.dataset.toc;
          if (!id) return;
          const target = document.getElementById(id);
          if (target) {
            e.preventDefault();
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            history.replaceState(null, '', '#' + id);
          }
        });
      }
    }

    // ─── Bouton Copier citation ────────────────────────────────
    const copyBtn = document.querySelector<HTMLButtonElement>('.copy-btn');
    if (copyBtn && navigator.clipboard) {
      copyBtn.addEventListener('click', async () => {
        const text = copyBtn.dataset.citation || '';
        try {
          await navigator.clipboard.writeText(text);
          const original = copyBtn.textContent;
          copyBtn.textContent = 'Copié';
          copyBtn.classList.add('copied');
          setTimeout(() => {
            copyBtn.textContent = original;
            copyBtn.classList.remove('copied');
          }, 2000);
        } catch {
          // Pas de fallback si clipboard refuse — rare en HTTPS, OK en
          // contexte où l'utilisateur peut sélectionner le texte à la main.
        }
      });
    }
  })();
</script>
