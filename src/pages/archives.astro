---
/**
 * Page Archives — /archives/
 *
 * Hero compact + pour chaque année (groupé via JS template) :
 *  - titre 48px + compteur en mono
 *  - lignes `120px 100px 1fr 160px` (date ISO, type uppercase accent,
 *    titre, pôle aligné à droite)
 *
 * Réf : design_handoff_carnet/Carnet B.html → Archives.
 */
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import { fetchCollection, fetchSite, filterPublished } from '../lib/payload';
import { formatDateIso, formatHeroLede, formatHeroTitle } from '../lib/site';

type Theme = { id: number | string; slug: string; name: string };

type Post = {
  id: number | string;
  numero: number;
  slug: string;
  title: string;
  type: 'analyse' | 'note' | 'fiche';
  themes?: Theme[] | null;
  publishedAt: string;
  draft?: boolean;
};

type SiteGlobal = {
  archives?: { heroTitle?: string; heroLede?: string };
};

const TYPE_LABEL: Record<Post['type'], string> = {
  analyse: 'Analyse',
  note: 'Note',
  fiche: 'Fiche',
};

const DEFAULT_TITLE = 'Tous les billets, par année.';
const DEFAULT_LEDE =
  'Le carnet est versionné : chaque billet a un numéro, une date de publication et, le cas échéant, une date de mise à jour. Les fiches thématiques sont régulièrement révisées.';

let posts: Post[] = [];
let site: SiteGlobal = {};
try {
  const raw = await fetchCollection<Post>('posts', {
    sort: '-publishedAt',
    limit: 1000,
    depth: 1,
  });
  posts = filterPublished(raw);
} catch (err) {
  console.warn('[archives] fetch failed, rendering empty:', (err as Error).message);
}
try {
  site = await fetchSite<SiteGlobal>();
} catch (err) {
  console.warn('[archives] fetchSite failed, using defaults:', (err as Error).message);
}

// Group by year (descending)
const byYear = new Map<string, Post[]>();
for (const p of posts) {
  const y = new Date(p.publishedAt).getFullYear().toString();
  if (!byYear.has(y)) byYear.set(y, []);
  byYear.get(y)!.push(p);
}
const years = [...byYear.keys()].sort().reverse();

const total = posts.length;

const heroTitleHtml = formatHeroTitle(
  site.archives?.heroTitle?.trim() || DEFAULT_TITLE,
);
const heroLedeHtml = formatHeroLede(
  site.archives?.heroLede?.trim() || DEFAULT_LEDE,
);
---

<Layout
  title="Archives — Carnet"
  description="Tous les billets du Carnet, par année."
>
  <Hero
    kicker={`Archives · ${total} billet${total > 1 ? 's' : ''}`}
    title={heroTitleHtml}
    lede={heroLedeHtml}
  />

  <section class="container archives">
    {years.length === 0 ? (
      <p class="empty">Aucun billet publié pour l'instant.</p>
    ) : (
      years.map((y) => {
        const list = byYear.get(y)!;
        return (
          <div class="arch-year">
            <h2>
              {y}
              {' '}
              <span class="mono count">· {list.length} billet{list.length > 1 ? 's' : ''}</span>
            </h2>
            {list.map((p) => {
              const primaryTheme = (p.themes ?? []).filter(
                (t): t is Theme => typeof t === 'object' && t !== null && 'slug' in t,
              )[0];
              return (
                <a class="arch-row" href={`/billets/${p.slug}/`}>
                  <div class="d">{formatDateIso(p.publishedAt)}</div>
                  <div class="ty">{TYPE_LABEL[p.type]}</div>
                  <div class="t">{p.title}</div>
                  <div class="p">{primaryTheme?.name ?? '—'}</div>
                </a>
              );
            })}
          </div>
        );
      })
    )}
  </section>
</Layout>

<style>
  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 80px;
  }

  /* Hero : centralisé dans src/components/Hero.astro */

  .archives {
    padding-top: 24px;
  }
  .archives .empty {
    padding: 64px 0;
    color: var(--color-muted);
    text-align: center;
    font-family: var(--font-sans);
  }

  /* Year groups */
  .arch-year {
    padding: 32px 0;
    border-bottom: 1px solid var(--color-rule);
  }
  .arch-year h2 {
    font-size: 48px;
    font-weight: 600;
    letter-spacing: -0.5px;
    margin: 0 0 24px;
  }
  .arch-year h2 .count {
    font-size: 14px;
    color: var(--color-muted);
    font-weight: 400;
  }
  .arch-row {
    display: grid;
    grid-template-columns: 120px 100px 1fr 160px;
    gap: 32px;
    padding: 14px 0;
    border-top: 1px solid var(--color-rule);
    align-items: baseline;
    color: inherit;
    transition: color 0.12s;
  }
  .arch-row:hover .t {
    color: var(--color-accent);
  }
  .arch-row .d {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-muted);
  }
  .arch-row .ty {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
  }
  .arch-row .t {
    font-size: 18px;
    line-height: 1.35;
    font-weight: 500;
    transition: color 0.12s;
  }
  .arch-row .p {
    font-family: var(--font-sans);
    font-size: 11px;
    color: var(--color-muted);
    text-align: right;
  }

  @media (max-width: 900px) {
    .container {
      padding: 0 24px;
    }
    .hero h1 {
      font-size: 40px;
    }
    .arch-year h2 {
      font-size: 32px;
    }
    .arch-row {
      grid-template-columns: 100px 1fr;
      gap: 16px;
    }
    .arch-row .ty,
    .arch-row .p {
      grid-column: 1 / -1;
    }
    .arch-row .p {
      text-align: left;
    }
  }
</style>
