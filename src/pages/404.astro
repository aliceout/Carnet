---
/**
 * Page 404 — quand un slug ne matche aucune route ni aucune entrée
 * Pages/Posts/Themes en base.
 */
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page introuvable — Carnet"
  description="Cette page n'existe pas — ou plus."
  noindex={true}
>
  <section class="container error-404">
    <div class="kicker mono">404</div>
    <h1>Cette page n'existe pas — ou plus.</h1>
    <p class="lede">
      Le lien que vous avez suivi est cassé, ou l'élément a été déplacé.
      Quelques entrées du carnet :
    </p>
    <ul class="links">
      <li><a href="/">Tous les billets</a></li>
      <li><a href="/archives/">Archives par année</a></li>
      <li><a href="/themes/">Index des thèmes</a></li>
      <li><a href="/about/">À propos du carnet</a></li>
    </ul>
  </section>
</Layout>

<style>
  .container {
    max-width: 720px;
    margin: 0 auto;
    padding: 120px 80px 64px;
  }
  .kicker {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--color-accent);
    margin-bottom: 14px;
  }
  h1 {
    font-size: 48px;
    line-height: 1.08;
    font-weight: 600;
    letter-spacing: -0.5px;
    margin: 0 0 20px;
  }
  .lede {
    font-family: var(--font-serif);
    font-size: 19px;
    line-height: 1.55;
    color: var(--color-muted);
    margin: 0 0 32px;
  }
  .links {
    font-family: var(--font-sans);
    font-size: 15px;
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 8px;
  }
  .links a {
    color: var(--color-ink);
    border-bottom: 1px solid var(--color-rule);
    padding-bottom: 4px;
    display: inline-block;
    transition: color 0.12s, border-color 0.12s;
  }
  .links a:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }
  @media (max-width: 900px) {
    .container {
      padding: 80px 24px 48px;
    }
    h1 {
      font-size: 32px;
    }
  }
</style>
