---
/**
 * Page d'un thème individuel — /theme/<slug>/
 *
 * Hero spécifique au thème (kicker `Thème · #slug`, h1 du thème,
 * description éditoriale, compteur + lien retour vers la vue
 * d'ensemble), puis le même flux d'items que l'accueil filtré
 * sur ce thème.
 *
 * Réf : design_handoff_carnet/Carnet B.html → PolePage (single).
 */
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';
import { fetchBySlug, fetchCollection, filterPublished } from '../../lib/payload';

type Theme = {
  id: number | string;
  slug: string;
  name: string;
  description?: string | null;
};

type ThemeRef = { id: number | string; slug: string; name: string };

type Post = {
  id: number | string;
  numero: number;
  slug: string;
  title: string;
  type: 'analyse' | 'note' | 'fiche';
  themes?: ThemeRef[] | null;
  publishedAt: string;
  lede: string;
  readingTime?: number | null;
  draft?: boolean;
};

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/themes/');

const theme = await fetchBySlug<Theme>('themes', slug);
if (!theme) {
  return new Response('Thème introuvable', { status: 404 });
}

let posts: Post[] = [];
try {
  const raw = await fetchCollection<Post>('posts', {
    where: [{ field: 'themes.slug', operator: 'equals', value: slug }],
    sort: '-publishedAt',
    limit: 500,
    depth: 2,
  });
  posts = filterPublished(raw);
} catch (err) {
  console.warn('[theme] posts fetch failed:', (err as Error).message);
}

const total = posts.length;
---

<Layout
  title={`${theme.name} — Carnet`}
  description={theme.description ?? `Tous les billets du Carnet sur le thème ${theme.name}.`}
>
  <section class="pole-hero">
    <div class="container">
      <div class="kicker mono">Thème · #{theme.slug}</div>
      <h1>{theme.name}</h1>
      {theme.description && <p class="desc">{theme.description}</p>}
      <div class="meta">
        <span>{total} billet{total > 1 ? 's' : ''}</span>
        <span aria-hidden="true">·</span>
        <a class="back mono" href="/themes/">← tous les thèmes</a>
      </div>
    </div>
  </section>

  <section class="container feed">
    {posts.length === 0 ? (
      <p class="empty">Aucun billet sous ce thème pour l'instant.</p>
    ) : (
      posts.map((p) => (
        <PostCard
          numero={p.numero}
          slug={p.slug}
          title={p.title}
          type={p.type}
          themes={p.themes}
          publishedAt={p.publishedAt}
          lede={p.lede}
          readingTime={p.readingTime}
          showThemes={false}
        />
      ))
    )}
  </section>
</Layout>

<style>
  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 80px;
  }

  .pole-hero {
    padding: 64px 0 48px;
    border-bottom: 1px solid var(--color-rule);
  }
  .pole-hero .kicker {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--color-accent);
    margin-bottom: 14px;
  }
  .pole-hero h1 {
    font-size: 56px;
    line-height: 1.05;
    font-weight: 600;
    letter-spacing: -0.6px;
    margin: 0 0 18px;
  }
  .pole-hero .desc {
    font-family: var(--font-serif);
    font-size: 19px;
    line-height: 1.55;
    color: var(--color-muted);
    max-width: 720px;
    margin: 0;
  }
  .pole-hero .meta {
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--color-muted);
    margin-top: 24px;
    display: flex;
    gap: 24px;
    align-items: center;
  }
  .pole-hero .back {
    color: var(--color-accent);
    transition: color 0.12s;
  }
  .pole-hero .back:hover {
    color: var(--color-ink);
  }

  .feed .empty {
    padding: 64px 0;
    color: var(--color-muted);
    text-align: center;
    font-family: var(--font-sans);
  }

  @media (max-width: 900px) {
    .container {
      padding: 0 24px;
    }
    .pole-hero h1 {
      font-size: 36px;
    }
  }
</style>
