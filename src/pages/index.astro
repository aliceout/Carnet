---
/**
 * Page d'accueil — hero + barre de filtres + flux d'items.
 *
 * Trois sections empilées (cf design_handoff_carnet/Carnet B.html → Home) :
 *  1. Hero : kicker meta + h1 + lede + 4 stats (analyses / notes / fiches / thèmes)
 *  2. Filtres : chips Type & Thème + compteur. Filtrage côté client en JS
 *     progressif via data-attrs ; persistance en URL hash. Lecture sans JS
 *     possible (la liste complète reste rendue).
 *  3. Flux : grille `120px 1fr 200px`, gap 48 px (cf. PostCard).
 *
 * Ajout d'une "Voir toutes les archives" en pied.
 */
import Layout from '../layouts/Layout.astro';
import PostCard from '../components/PostCard.astro';
import { fetchCollection, filterPublished } from '../lib/payload';

type Theme = { id: number | string; slug: string; name: string };

type Post = {
  id: number | string;
  numero: number;
  slug: string;
  title: string;
  type: 'analyse' | 'note' | 'fiche';
  themes?: Theme[] | null;
  publishedAt: string;
  lede: string;
  readingTime?: number | null;
  draft?: boolean;
};

let posts: Post[] = [];
let themes: Theme[] = [];
try {
  const raw = await fetchCollection<Post>('posts', {
    sort: '-publishedAt',
    limit: 500,
    depth: 2,
  });
  posts = filterPublished(raw);
  themes = await fetchCollection<Theme>('themes', { sort: 'name', limit: 100, depth: 0 });
} catch (err) {
  console.warn('[home] fetch failed, rendering empty:', (err as Error).message);
}

// Stats par type
const total = posts.length;
const counts = {
  analyse: posts.filter((p) => p.type === 'analyse').length,
  note: posts.filter((p) => p.type === 'note').length,
  fiche: posts.filter((p) => p.type === 'fiche').length,
};

// Top thèmes utilisés (pour la barre de filtres) — max 6 chips après "Tous"
const themeUsage = new Map<string, { theme: Theme; count: number }>();
for (const post of posts) {
  for (const t of post.themes ?? []) {
    if (typeof t !== 'object' || t === null) continue;
    const cur = themeUsage.get(t.slug) ?? { theme: t, count: 0 };
    cur.count++;
    themeUsage.set(t.slug, cur);
  }
}
const topThemes = [...themeUsage.values()]
  .sort((a, b) => b.count - a.count)
  .slice(0, 6)
  .map((x) => x.theme);

// Année du carnet (pour le hero meta) — plus ancien post
const oldestYear = posts.length
  ? Math.min(...posts.map((p) => new Date(p.publishedAt).getFullYear()))
  : new Date().getFullYear();
const monthLabel = (() => {
  if (!posts.length) return '';
  const oldest = posts.reduce((acc, p) =>
    new Date(p.publishedAt) < new Date(acc.publishedAt) ? p : acc,
  );
  const d = new Date(oldest.publishedAt);
  const months = [
    'janvier',
    'février',
    'mars',
    'avril',
    'mai',
    'juin',
    'juillet',
    'août',
    'septembre',
    'octobre',
    'novembre',
    'décembre',
  ];
  return `${months[d.getMonth()]} ${d.getFullYear()}`;
})();
---

<Layout bodyClass="justify">
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="meta">
        Carnet · {total} billet{total > 1 ? 's' : ''}{monthLabel ? ` · depuis ${monthLabel}` : ''}
      </div>
      <h1>
        Notes de recherche en <em>études de genre</em><br />
        et en relations internationales.
      </h1>
      <p class="lede">
        Analyses longues, notes de lecture et fiches thématiques sur le genre,
        la géopolitique et les droits LGBTQI+ dans les rapports internationaux.
        Principalement en français.
      </p>
      <div class="stats">
        <div><span class="n">{counts.analyse}</span>analyse{counts.analyse > 1 ? 's' : ''}</div>
        <div><span class="n">{counts.note}</span>note{counts.note > 1 ? 's' : ''} de lecture</div>
        <div><span class="n">{counts.fiche}</span>fiche{counts.fiche > 1 ? 's' : ''} thématique{counts.fiche > 1 ? 's' : ''}</div>
        <div><span class="n">{themes.length}</span>thème{themes.length > 1 ? 's' : ''}</div>
      </div>
    </div>
  </section>

  <!-- Filtres -->
  <section class="filters" id="filters" data-total={total}>
    <div class="container">
      <div class="row">
        <div class="grp" role="group" aria-label="Filtrer par type">
          <span class="lbl">Type</span>
          <button class="chip on" type="button" data-filter-type="all">Tous</button>
          <button class="chip" type="button" data-filter-type="analyse">Analyses</button>
          <button class="chip" type="button" data-filter-type="note">Notes</button>
          <button class="chip" type="button" data-filter-type="fiche">Fiches</button>
        </div>
        {topThemes.length > 0 && (
          <>
            <div class="sep" aria-hidden="true"></div>
            <div class="grp" role="group" aria-label="Filtrer par thème">
              <span class="lbl">Thème</span>
              <button class="chip on" type="button" data-filter-theme="all">Tous</button>
              {topThemes.map((t) => (
                <button
                  class="chip"
                  type="button"
                  data-filter-theme={t.slug}
                  title={t.name}
                >
                  {t.name}
                </button>
              ))}
            </div>
          </>
        )}
        <div class="count" id="filter-count">
          {total} billet{total > 1 ? 's' : ''} · tri : récent
        </div>
      </div>
    </div>
  </section>

  <!-- Flux -->
  <section class="container feed">
    {posts.length === 0 ? (
      <p class="empty">Aucun billet publié pour l'instant.</p>
    ) : (
      posts.map((p) => (
        <PostCard
          numero={p.numero}
          slug={p.slug}
          title={p.title}
          type={p.type}
          themes={p.themes}
          publishedAt={p.publishedAt}
          lede={p.lede}
          readingTime={p.readingTime}
        />
      ))
    )}
    <div class="archives-link">
      <a href="/archives/" class="btn-link">Voir toutes les archives</a>
    </div>
  </section>
</Layout>

<style>
  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 80px;
  }
  @media (max-width: 900px) {
    .container {
      padding: 0 24px;
    }
  }

  /* Hero */
  .hero {
    padding: 72px 0 48px;
    border-bottom: 1px solid var(--color-rule);
  }
  .hero .meta {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 18px;
  }
  .hero h1 {
    font-size: 64px;
    line-height: 1.04;
    font-weight: 600;
    letter-spacing: -0.7px;
    margin: 0 0 20px;
    max-width: 1080px;
  }
  .hero h1 em {
    font-weight: 500;
  }
  .hero p.lede {
    font-family: var(--font-serif);
    font-size: 20px;
    line-height: 1.55;
    color: var(--color-muted);
    max-width: 720px;
    margin: 0;
  }
  .hero .stats {
    margin-top: 32px;
    display: flex;
    gap: 48px;
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--color-muted);
    flex-wrap: wrap;
  }
  .hero .stats .n {
    display: block;
    font-family: var(--font-serif);
    font-size: 24px;
    color: var(--color-ink);
    font-weight: 600;
  }
  @media (max-width: 720px) {
    .hero h1 {
      font-size: 40px;
    }
    .hero .stats {
      gap: 24px;
    }
  }

  /* Filtres */
  .filters {
    padding: 18px 0;
    border-bottom: 1px solid var(--color-rule);
    font-family: var(--font-sans);
    font-size: 13px;
  }
  .filters .row {
    display: flex;
    gap: 24px;
    align-items: center;
    flex-wrap: wrap;
  }
  .filters .grp {
    display: flex;
    gap: 6px;
    align-items: center;
    flex-wrap: wrap;
  }
  .filters .lbl {
    color: var(--color-muted);
    padding-right: 8px;
  }
  .chip {
    padding: 6px 12px;
    border-radius: 999px;
    border: 1px solid var(--color-rule);
    background: transparent;
    color: var(--color-muted);
    cursor: pointer;
    font: inherit;
    transition: color 0.12s, border-color 0.12s, background 0.12s;
  }
  .chip.on {
    background: var(--color-ink);
    color: var(--color-bg);
    border-color: var(--color-ink);
  }
  .chip:hover:not(.on) {
    border-color: var(--color-ink);
    color: var(--color-ink);
  }
  .filters .count {
    margin-left: auto;
    color: var(--color-muted);
  }
  .filters .sep {
    width: 1px;
    height: 20px;
    background: var(--color-rule);
  }

  /* Flux */
  .feed {
    /* Item border-bottom déjà géré dans PostCard */
  }
  .feed .empty {
    padding: 64px 0;
    color: var(--color-muted);
    text-align: center;
    font-family: var(--font-sans);
  }
  .archives-link {
    padding: 32px 0;
    text-align: center;
  }
  .btn-link {
    padding: 10px 24px;
    border-radius: 999px;
    border: 1px solid var(--color-ink);
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: 13px;
    transition: background 0.12s, color 0.12s;
    display: inline-block;
  }
  .btn-link:hover {
    background: var(--color-ink);
    color: var(--color-bg);
  }
</style>

<script>
  // Filtres home — JS progressif. Lecture sans JS = tout est rendu.
  // Sélection persistée en URL hash : #type=analyse&theme=queer-theory
  // Format compact : si 'all' partout, hash retiré.
  (function () {
    const filters = document.getElementById('filters');
    const countEl = document.getElementById('filter-count');
    const items = Array.from(document.querySelectorAll<HTMLElement>('.item'));
    if (!filters || !countEl || !items.length) return;

    type State = { type: string; theme: string };
    const state: State = { type: 'all', theme: 'all' };
    const total = Number(filters.getAttribute('data-total') || items.length);

    function readHash(): State {
      const hash = window.location.hash.replace(/^#/, '');
      if (!hash) return { type: 'all', theme: 'all' };
      const params = new URLSearchParams(hash);
      return {
        type: params.get('type') || 'all',
        theme: params.get('theme') || 'all',
      };
    }

    function writeHash() {
      const params = new URLSearchParams();
      if (state.type !== 'all') params.set('type', state.type);
      if (state.theme !== 'all') params.set('theme', state.theme);
      const str = params.toString();
      const newHash = str ? '#' + str : '';
      if (newHash !== window.location.hash) {
        history.replaceState(null, '', window.location.pathname + newHash);
      }
    }

    function applyFilters() {
      let visible = 0;
      for (const item of items) {
        const itemType = item.getAttribute('data-type') || '';
        const itemThemes = (item.getAttribute('data-themes') || '').split(' ').filter(Boolean);
        const okType = state.type === 'all' || itemType === state.type;
        const okTheme = state.theme === 'all' || itemThemes.includes(state.theme);
        const show = okType && okTheme;
        item.style.display = show ? '' : 'none';
        if (show) visible++;
      }
      countEl.textContent =
        `${visible} billet${visible > 1 ? 's' : ''} sur ${total} · tri : récent`;
    }

    function syncChipsFromState() {
      filters.querySelectorAll<HTMLButtonElement>('[data-filter-type]').forEach((btn) => {
        btn.classList.toggle('on', btn.dataset.filterType === state.type);
      });
      filters.querySelectorAll<HTMLButtonElement>('[data-filter-theme]').forEach((btn) => {
        btn.classList.toggle('on', btn.dataset.filterTheme === state.theme);
      });
    }

    filters.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('button[data-filter-type], button[data-filter-theme]');
      if (!btn) return;
      if (btn.dataset.filterType) state.type = btn.dataset.filterType;
      if (btn.dataset.filterTheme) state.theme = btn.dataset.filterTheme;
      syncChipsFromState();
      applyFilters();
      writeHash();
    });

    // Init from URL hash
    const initial = readHash();
    state.type = initial.type;
    state.theme = initial.theme;
    syncChipsFromState();
    applyFilters();
  })();
</script>
