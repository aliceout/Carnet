---
/**
 * Page d'accueil — placeholder MVP-0.
 * Sera remplacée par le hero + barre de filtres + flux d'items
 * une fois les collections Payload câblées et le design porté.
 * Réf : design_handoff_carnet/Carnet B.html → Home component.
 */
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <section style="padding: 120px 80px; max-width: 1280px; margin: 0 auto;">
    <div
      class="sans"
      style="font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-accent); margin-bottom: 18px;"
    >
      Carnet · placeholder
    </div>
    <h1 style="font-size: 64px; line-height: 1.04; font-weight: 600; letter-spacing: -0.7px; margin: 0 0 20px;">
      Notes de recherche en <em style="font-weight: 500;">études de genre</em><br />
      et en relations internationales.
    </h1>
    <p
      class="sans"
      style="font-size: 20px; line-height: 1.55; color: var(--color-muted); max-width: 720px;"
    >
      Squelette technique en place. Le design hi-fi sera porté dans les
      étapes suivantes (hero + barre de filtres + flux d'items + filtres
      Type/Thèmes).
    </p>
  </section>
</Layout>
