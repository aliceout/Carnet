---
/**
 * Page d'un tag individuel — /tag/<slug>/
 *
 * Hero compact (kicker mono `#slug`, h1 nom du tag, compteur + lien
 * retour vers /tags/), puis flux des billets qui ont ce tag. Calqué
 * sur /theme/<slug>/ mais sans description éditoriale (les tags sont
 * non-éditoriaux par design).
 */
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import PostCard from '../../components/PostCard.astro';
import { fetchBySlug, fetchCollection, filterPublished } from '../../lib/payload';

type Tag = {
  id: number | string;
  slug: string;
  name: string;
};

type ThemeRef = { id: number | string; slug: string; name: string };

type Post = {
  id: number | string;
  numero: number;
  slug: string;
  title: string;
  type: 'analyse' | 'note' | 'fiche';
  themes?: ThemeRef[] | null;
  publishedAt: string;
  lede: string;
  readingTime?: number | null;
  draft?: boolean;
};

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/tags/');

const tag = await fetchBySlug<Tag>('tags', slug);
if (!tag) {
  return new Response('Tag introuvable', { status: 404 });
}

let posts: Post[] = [];
try {
  const raw = await fetchCollection<Post>('posts', {
    where: [{ field: 'tags.slug', operator: 'equals', value: slug }],
    sort: '-publishedAt',
    limit: 500,
    depth: 2,
  });
  posts = filterPublished(raw);
} catch (err) {
  console.warn('[tag] posts fetch failed:', (err as Error).message);
}

const total = posts.length;
---

<Layout
  title={`#${tag.slug}`}
  description={`Billets du Carnet taggés #${tag.slug}.`}
>
  <Hero
    kicker={`Tag · #${tag.slug}`}
    kickerVariant="mono"
    title={tag.name}
  >
    <div class="hero-bottom-meta">
      <span>{total} billet{total > 1 ? 's' : ''}</span>
      <span aria-hidden="true">·</span>
      <a class="back mono" href="/tags/">← tous les tags</a>
    </div>
  </Hero>

  <section class="container feed">
    {posts.length === 0 ? (
      <p class="empty">Aucun billet sous ce tag pour l'instant.</p>
    ) : (
      posts.map((p) => (
        <PostCard
          numero={p.numero}
          slug={p.slug}
          title={p.title}
          type={p.type}
          themes={p.themes}
          publishedAt={p.publishedAt}
          lede={p.lede}
          readingTime={p.readingTime}
        />
      ))
    )}
  </section>
</Layout>

<style>
  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 80px;
  }

  .hero-bottom-meta {
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--color-muted);
    margin-top: 24px;
    display: flex;
    gap: 24px;
    align-items: center;
  }
  .hero-bottom-meta .back {
    color: var(--color-accent);
    transition: color 0.12s;
  }
  .hero-bottom-meta .back:hover {
    color: var(--color-ink);
  }

  .feed .empty {
    padding: 64px 0;
    color: var(--color-muted);
    text-align: center;
    font-family: var(--font-sans);
  }

  @media (max-width: 900px) {
    .container {
      padding: 0 24px;
    }
  }
</style>
